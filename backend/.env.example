PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/pfe_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# CORS
CLIENT_URL=http://localhost:5173
# Check service status
net start MongoDB

# Or open Task Manager → Services → look for "MongoDB"
```

